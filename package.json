{
  "name": "fotosnap",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:up": "docker compose -f infra/dev/docker-compose.yml -p fotosnap up -d",
    "db:down": "docker compose -f infra/dev/docker-compose.yml -p fotosnap down",
    "db:logs": "docker compose -f infra/dev/docker-compose.yml -p fotosnap logs -f",
    "db:reset": "docker compose -f infra/dev/docker-compose.yml -p fotosnap down -v",
    "trpc:generate": "nestjs-trpc generate --entrypoint apps/backend/src/app.module.ts --output packages/trpc/src/server",
    "trpc:watch": "nestjs-trpc generate --entrypoint apps/backend/src/app.module.ts --output packages/trpc/src/server --watch"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.8.15",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.10.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
